    "title": "Sum Divisible by k",
    "description": "Given an integer array nums of size n and an integer k. If sum of elements of array is divisible by k return true, otherwise return false.",
    "examples": [
      {
        "input": "nums = [ 1, 2, 3 ]\nk = 5",
        "output": "false",
        "explanation": "( 1 + 2 + 3 ) % 5 != 0",
        "_id": {
          "$oid": "685d2c8b7c5c8b56fc5a762c"
        }
      },
      {
        "input": "nums = [ 5, 10, 15 ]\nk = 3",
        "output": "true",
        "explanation": "( 5 + 10 + 15 ) % 3 == 0",
        "_id": {
          "$oid": "685d2c8b7c5c8b56fc5a762d"
        }
      }
    ],
